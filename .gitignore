# PDFフォルダ以外を除外
/*
!PDF/
!special/
special/*.txt
!.gitignore

# PDF内の不要ファイル
PDF/.DS_Store
PDF/**/.DS_Store

# ルートのPNG（imagesフォルダにあるのでルートは不要）
PDF/*.png

# 各顧客フォルダ内のPNG（imagesフォルダを参照するように後で修正）
PDF/*様/*.png

# 開発用ファイル
PDF/__pycache__/
PDF/*.py
PDF/*.txt
PDF/*.css

# テスト用HTML
PDF/test_*.html
PDF/premium_pdf_*.html
PDF/kantei.html

# 古い単体HTMLファイル（フォルダ版を使用）
# Base64埋め込み版はファイルサイズが大きいので除外
PDF/*_本鑑定書_*.html
PDF/*_アクションプラン_*.html
PDF/本鑑定書_*.html
PDF/やっちん様_*.html
PDF/*_kantei_*.html
